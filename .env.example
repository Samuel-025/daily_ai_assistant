# ════════════════════════════════════════════════════
#   Daily AI Assistant — Environment Configuration
#   Copy this file:  cp .env.example .env
#   Then fill in your values below
# ════════════════════════════════════════════════════

# ── Ollama (Local LLM — FREE, runs on your machine) ──
OLLAMA_API_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ── OpenAI ───────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o

# ── Anthropic Claude ─────────────────────────────────
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ── Groq (fast & free tier available) ────────────────
# Get key: https://console.groq.com/
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-70b-versatile

# ── Cohere ───────────────────────────────────────────
# Get key: https://dashboard.cohere.com/
COHERE_API_KEY=
COHERE_DEFAULT_MODEL=command-r-plus

# ── Weather (optional — for real weather data) ────────
# Get free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=
USER_CITY=Vasind
USER_COUNTRY=IN

# ── News (optional — for daily news briefing) ─────────
# Get free key: https://newsapi.org/
NEWS_API_KEY=

# ── App Behaviour ─────────────────────────────────────
# Preferred LLM provider: ollama | openai | anthropic | groq | cohere
DEFAULT_PROVIDER=ollama
# Use local Ollama first before falling back to cloud
USE_LOCAL_FIRST=true
